FROM python@sha256:8a7e7cc04fd3e2bd787f7f24e22d5d119aa590d429b50c95dfe12b3abe52f48b

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

ARG REQUIREMENTS_LOCK=artifacts/wheelhouse/linux-amd64-cp312/requirements-linux-amd64-cp312.lock
COPY ${REQUIREMENTS_LOCK} /tmp/requirements.lock
RUN pip install --no-cache-dir \
    --index-url=https://pypi.org/simple \
    --require-hashes \
    --only-binary=:all: \
    -r /tmp/requirements.lock \
    && pip check \
    && rm -f /tmp/requirements.lock

COPY backend ./backend
COPY device_agents ./device_agents
COPY alembic ./alembic
COPY alembic.ini .
COPY VERSION .

CMD ["python", "-m", "backend.worker"]
