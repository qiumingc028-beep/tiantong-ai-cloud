--- SQL FILE /tmp/alpha-evidence-catalog.sql ---
SELECT version_num AS alembic_current_revision
FROM alembic_version;

SELECT conname, contype, pg_get_constraintdef(oid) AS definition
FROM pg_constraint
WHERE conrelid = 'alpha_workflow_runs'::regclass
  AND conname IN (
    'uq_alpha_workflow_runs_trace_id',
    'uq_alpha_workflow_runs_workflow_id',
    'uq_alpha_workflow_runs_root_span_id',
    'uq_alpha_workflow_runs_orchestrator_run_id',
    'uq_alpha_workflow_runs_research_report_id',
    'uq_alpha_workflow_runs_skill_invocation_id'
  )
ORDER BY conname;

SELECT COUNT(*) AS required_and_trace_unique_constraint_count
FROM pg_constraint
WHERE conrelid = 'alpha_workflow_runs'::regclass
  AND contype = 'u'
  AND conname IN (
    'uq_alpha_workflow_runs_trace_id',
    'uq_alpha_workflow_runs_workflow_id',
    'uq_alpha_workflow_runs_root_span_id',
    'uq_alpha_workflow_runs_orchestrator_run_id',
    'uq_alpha_workflow_runs_research_report_id',
    'uq_alpha_workflow_runs_skill_invocation_id'
  );

SELECT i.relname AS index_name, x.indisunique, pg_get_indexdef(x.indexrelid) AS definition
FROM pg_index AS x
JOIN pg_class AS i ON i.oid = x.indexrelid
JOIN pg_class AS t ON t.oid = x.indrelid
JOIN pg_namespace AS n ON n.oid = t.relnamespace
WHERE n.nspname = 'public'
  AND t.relname = 'alpha_workflow_runs'
  AND i.relname IN (
    'ix_alpha_workflow_runs_knowledge_asset_id',
    'uq_alpha_workflow_runs_knowledge_asset_id'
  )
ORDER BY i.relname;

SELECT indexname, indexdef
FROM pg_indexes
WHERE schemaname = 'public'
  AND tablename = 'alpha_workflow_runs'
  AND indexname IN (
    'ix_alpha_workflow_runs_knowledge_asset_id',
    'uq_alpha_workflow_runs_knowledge_asset_id'
  )
ORDER BY indexname;

SELECT knowledge_asset_id, COUNT(*) AS run_count
FROM alpha_workflow_runs
WHERE knowledge_asset_id = 'aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa'
GROUP BY knowledge_asset_id;

SELECT COUNT(*) AS rows_with_nullable_unique_fields
FROM alpha_workflow_runs
WHERE workflow_id IS NULL
  AND root_span_id IS NULL
  AND orchestrator_run_id IS NULL
  AND research_report_id IS NULL
  AND skill_invocation_id IS NULL;

SELECT tgname, pg_get_triggerdef(oid) AS definition
FROM pg_trigger
WHERE tgrelid = 'alpha_workflow_events'::regclass
  AND NOT tgisinternal
  AND tgname IN (
    'alpha_workflow_events_no_update',
    'alpha_workflow_events_no_delete'
  )
ORDER BY tgname;
