APP_ENV=production

# Runtime application database user. Create this low-privilege user manually
# before switching production traffic to this compose file.
DATABASE_URL=postgresql+psycopg2://tiantong_app:<APP_DB_PASSWORD>@postgres:5432/tiantong_ai

# PostgreSQL bootstrap/admin user used by the postgres container.
# Do not use this account in DATABASE_URL for normal backend runtime.
POSTGRES_DB=tiantong_ai
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=<POSTGRES_ADMIN_PASSWORD>

# Redis must require authentication in production.
REDIS_PASSWORD=<REDIS_PASSWORD>
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/0

# Use a long random value. Never reuse examples from docs.
JWT_SECRET=<JWT_SECRET_64_PLUS_CHARS>
BOSS_INITIAL_PASSWORD=<UNIQUE_INITIAL_BOSS_PASSWORD_12_PLUS_CHARS>

# Comma-separated HTTPS origins. Wildcards and empty values are rejected.
CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOW_CREDENTIALS=true
DEBUG=false

# Optional one-time recovery password. Rotate after use.
ADMIN_RESET_PASSWORD=<ONE_TIME_ADMIN_RECOVERY_PASSWORD>

# Keep mock until real model provider approval is completed.
AI_PROVIDER=mock
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Host paths on the production server. These files must not be committed.
TLS_CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem

HTTP_PORT=80
HTTPS_PORT=443
